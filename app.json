{
  "expo": {
    "name": "AeroBrief",
    "slug": "aerobrif-mobile",
    "version": "1.0.0",
    "orientation": "portrait",

    "icon": "./assets/images/icon.png",

    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#1E3A8A"
      },

      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.maxgruum37.aerobrifmobile",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyA3eHnfz56zXGOQnc56TZdeuXnUthYYobU"
        }
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash.png",
          "imageWidth": 300,
          "resizeMode": "contain",
          "backgroundColor": "#0A192F",
          "dark": {
            "backgroundColor": "#0A192F"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0c3c4212-d3f3-4077-a76f-d6d2d3807456"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/0c3c4212-d3f3-4077-a76f-d6d2d3807456"
    }
  }
